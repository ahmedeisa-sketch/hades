DATABASE_URL="postgresql://hades:hades_dev_password@localhost:5432/hades_fund?schema=public"
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Document storage (Phase 2, Module 4).
# STORAGE_PROVIDER: "local" (filesystem, default/dev) or "s3" (production — see
# src/common/storage/s3-storage.service.ts to complete the integration).
STORAGE_PROVIDER="local"
# Directory used by the local provider.
STORAGE_LOCAL_DIR="./storage"
# Used by the s3 provider.
STORAGE_BUCKET="hades-fund-documents"

# Notifications (Phase 4, Module 11).
# NOTIFICATION_PROVIDER: "log" (writes to app log, default/dev) or "email"
# (SES/SendGrid/SMTP — see src/notifications/senders/email-notification.sender.ts).
NOTIFICATION_PROVIDER="log"
